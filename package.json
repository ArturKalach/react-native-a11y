{
  "name": "react-native-a11y",
  "version": "0.7.0",
  "description": "Improvements of a11y for ReactNative, this library improve work with reader and keyboard focus and reader in general.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "!**/CLAUDE.md",
    "!**/docs"
  ],
  "scripts": {
    "example": "yarn workspace react-native-a11y-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "release": "release-it --only-version",
    "release-ni": "release-it --no-increment"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "accessibility",
    "a11y",
    "react-native a11y",
    "WCAG",
    "screen reader",
    "VoiceOver",
    "TalkBack",
    "reader focus",
    "focus order",
    "focus trap",
    "focus lock",
    "announcements",
    "keyboard",
    "physical keyboard",
    "external keyboard",
    "keyboard focus",
    "UIFocusHaloEffect",
    "defaultFocusHighlightEnabled"
  ],
  "repository": "https://github.com/ArturKalach/react-native-a11y",
  "author": "Artur Kalach <artur.kalach.andreevich@gmail.com> (https://github.com/ArturKalach)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ArturKalach/react-native-a11y/issues"
  },
  "homepage": "https://github.com/ArturKalach/react-native-a11y#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.4",
    "@react-native/eslint-config": "0.83.4",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.30",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "prettier": "^2.8.8",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-builder-bob": "^0.40.18",
    "release-it": "^20.2.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "resolutions": {
    "@types/react": "^18.3.30"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNA11ySpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativea11y"
    },
    "ios": {
      "componentProvider": {
        "A11yView": "RCA11yView",
        "A11yLock": "RCA11yLockView",
        "A11yOrder": "RCA11yOrderView",
        "A11yCard": "RCA11yCardView",
        "A11yPaneTitle": "RCA11yPaneTitleView",
        "A11yFocusGroup": "RCA11yFocusGroup",
        "A11yTextInputWrapper": "RCA11yTextInputWrapper"
      },
      "modulesProvider": {
        "A11yAnnounceModule": "RCA11yAnnounceModule",
        "A11yKeyboardModule": "RCA11yKeyboardModule",
        "A11yKeyboardConnectedModule": "RCA11yKeyboardConnectedModule",
        "A11yOrderModule": "RCA11yOrderModule"
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "react/react-in-jsx-scope": "off",
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}
